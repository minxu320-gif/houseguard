# =============================================================================
# 方案 3（推荐长期）：复制本文件为 .env 并填写真实值，勿将 .env 提交仓库
# =============================================================================
# 本地开发可优先使用下面一组（配合 DEBUG=true；生产请删除 DJANGO_INSECURE_DEV）
#
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SECRET_KEY=xxx
DJANGO_INSECURE_DEV=1
DJANGO_DEBUG=true

# --- Django（生产请改为 DEBUG=false，去掉 DJANGO_INSECURE_DEV，使用强随机 SECRET_KEY）---
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# 仅当 DEBUG=true 且未设置 SECRET_KEY 时，DJANGO_INSECURE_DEV=1 才会启用内置临时密钥（仍不推荐）
# DJANGO_INSECURE_DEV=1

# 本地无 HTTPS 时建议 false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# --- MySQL（禁止在仓库中写真实密码；部署时注入）---
# 若出现 1045 且堆栈里有 caching_sha2_password_auth：多为 MySQL 8 认证插件与 PyMySQL 兼容问题。
# 解决：在 MySQL 里执行 scripts/mysql_native_auth.sql（把密码改成你的），或确认密码与 mysql 里一致。
# DEBUG 下 settings 会默认传 ssl_disabled=True；若需关闭该行为：DJANGO_MYSQL_SSL_DISABLED=0
# DJANGO_MYSQL_SSL_DISABLED=0
MYSQL_DATABASE=houseguard
MYSQL_USER=root
MYSQL_PASSWORD=your-strong-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
# compose 对外映射
MYSQL_PUBLISH_PORT=3307

# --- Redis（可选；不设则使用 LocMem cache）---
# REDIS_URL=redis://redis:6379/1
REDIS_PUBLISH_PORT=6379

# --- 对外端口（Docker nginx）---
HTTP_PUBLISH_PORT=8080

# --- AI（可选）---
DEEPSEEK_API_KEY=
